{
  "name": "thomasvaeth.github.io",
  "version": "4.0.0",
  "type": "module",
  "description": "Thomas Vaeth is a Design Technologist at Square in Seattle, Washington.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write src",
    "lint": "eslint src && eslint .",
    "lint:fix": "eslint src --fix",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "author": {
    "name": "Thomas Vaeth",
    "email": "thomas.vaeth@gmail.com",
    "url": "https://thomasvaeth.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thomasvaeth/thomasvaeth.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/thomasvaeth/thomasvaeth.github.io/issues"
  },
  "engines": {
    "node": "24.14.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.10",
    "lenis": "^1.3.21"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "netlify-cli": "^24.9.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sass-embedded": "^1.99.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.5"
  },
  "lint-staged": {
    "*.{js,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md,html}": "prettier --write"
  }
}
